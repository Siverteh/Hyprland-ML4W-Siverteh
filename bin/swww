#!/usr/bin/env bash

set -euo pipefail

runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
display_name="${WAYLAND_DISPLAY:-wayland-1}"
socket_path="$runtime_dir/${display_name}-awww-daemon.sock"

daemon_ready() {
    /usr/bin/awww query >/dev/null 2>&1
}

ensure_daemon() {
    if daemon_ready; then
        return
    fi

    if ! pgrep -x awww-daemon >/dev/null 2>&1; then
        rm -f "$socket_path"
        nohup /usr/bin/awww-daemon >/tmp/awww-daemon.log 2>&1 </dev/null &
    fi

    for _ in $(seq 1 30); do
        if daemon_ready; then
            return
        fi
        sleep 0.1
    done
}

cmd="${1:-}"

case "$cmd" in
img|clear|restore|query|pause)
    ensure_daemon
    ;;
kill)
    exec /usr/bin/awww "$@"
    ;;
*)
    ;;
esac

exec /usr/bin/awww "$@"
